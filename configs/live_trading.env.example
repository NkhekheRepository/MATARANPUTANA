# Live Trading Configuration
# ==========================
# This file defines all environment variables and settings required
# for live trading mode. Copy to .env and fill in values.

# ============================================================================
# TRADING MODE (CRITICAL)
# ============================================================================
# Default: paper. Must be explicitly set to "live" for real trading.
# NEVER set to "live" without first testing on testnet.
TRADING_MODE=paper

# ============================================================================
# BINANCE CREDENTIALS
# ============================================================================
# Required for live trading. Use API keys with trading permissions only.
# NEVER commit these to version control.
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# Server type: REAL or TESTNET
# ALWAYS start with TESTNET for validation
BINANCE_SERVER=TESTNET

# ============================================================================
# RISK LIMITS
# ============================================================================
# Maximum position size per symbol (contracts/lots)
MAX_POSITION_SIZE=10

# Maximum daily loss in quote currency (e.g., USDT)
MAX_DAILY_LOSS=1000

# Maximum drawdown percentage before circuit breaker
MAX_DRAWDOWN_PCT=20

# ============================================================================
# SYNC & HEALTH
# ============================================================================
# How often to sync account/positions with exchange (seconds)
SYNC_INTERVAL_SECONDS=60

# ============================================================================
# API GATEWAY
# ============================================================================
# Rate limiting: max requests per window
API_RATE_LIMIT=120
API_RATE_WINDOW=60

# JWT authentication
JWT_SECRET_KEY=
JWT_EXPIRE_MINUTES=60
API_KEYS=

# ============================================================================
# POSITION SIZING
# ============================================================================
# Risk per trade as percentage of equity (default 1%)
RISK_PER_TRADE_PCT=1.0

# Maximum position as percentage of equity (default 10%)
MAX_POSITION_PCT=10.0

# Minimum order size
MIN_ORDER_SIZE=0.001

# Default ATR/volatility percentage for sizing when real ATR unavailable (default 2%)
DEFAULT_ATR_PCT=2.0

# ============================================================================
# ORDER ROUTING
# ============================================================================
# Default order type: limit or market
DEFAULT_ORDER_TYPE=limit

# ATR period for volatility calculation (number of kline bars)
ATR_PERIOD=14

# ============================================================================
# REDIS (for event persistence and caching)
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379

# ============================================================================
# ORDER TRACKER PERSISTENCE
# ============================================================================
# Directory for crash-recovery of in-flight orders
ORDER_TRACKER_DIR=/vnpy/memory/orders

# ============================================================================
# WEBSOCKET
# ============================================================================
BINANCE_WS_URL=wss://stream.binance.com:9443/ws
PAPER_MODE=true
